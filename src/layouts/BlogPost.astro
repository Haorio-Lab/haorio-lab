---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category, tags } = Astro.props;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: min(var(--max-content), calc(100% - 1rem));
				max-width: 100%;
				margin: 0 auto;
			}
			article {
				display: grid;
				gap: 1.25rem;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				width: min(1020px, 100%);
				margin: 0 auto;
				border-radius: 16px;
				box-shadow: var(--box-shadow);
				aspect-ratio: 2 / 1;
				object-fit: cover;
			}
			.prose {
				width: min(var(--max-reading), 100%);
				margin: auto;
				padding: 0.5rem 0 0;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1.4rem;
				padding: 0.5rem 0 0;
				text-align: left;
			}
			.title h1 {
				margin: 0.4rem 0 0.7rem 0;
				line-height: 1.15;
			}
			.meta {
				display: flex;
				justify-content: flex-start;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-bottom: 0.8rem;
			}
			.badge {
				display: inline-flex;
				align-items: center;
				padding: 0.35rem 0.7rem;
				border-radius: 999px;
				background: rgba(var(--accent), 0.08);
				color: rgb(var(--accent-dark));
				font-size: 0.88rem;
				font-weight: 700;
			}
			.date {
				margin-bottom: 0.2rem;
				color: rgb(var(--gray));
				font-size: 0.96rem;
			}
			.last-updated-on {
				font-style: italic;
				margin-top: 0.2rem;
			}
			.tags {
				display: flex;
				gap: 0.45rem;
				justify-content: flex-start;
				flex-wrap: wrap;
				margin-top: 0.8rem;
			}
			.tag {
				padding: 0.28rem 0.65rem;
				border-radius: 999px;
				background: rgba(var(--gray), 0.12);
				color: rgb(var(--gray-dark));
				font-size: 0.84rem;
			}
			@media (max-width: 720px) {
				main {
					width: calc(100% - 1rem);
				}
				.hero-image img {
					border-radius: 14px;
				}
				.prose {
					padding-top: 0;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img src={heroImage} alt={title} loading="eager" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="meta">
							<span class="badge">{category}</span>
						</div>
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
						{tags?.length > 0 && (
							<div class="tags">
								{tags.map((tag: string) => <span class="tag">#{tag}</span>)}
							</div>
						)}
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
