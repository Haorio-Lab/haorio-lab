---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category, tags } = Astro.props;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				width: min(1020px, calc(100% - 2rem));
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0.35em 0 0.5em 0;
				line-height: 1.15;
			}
			.meta {
				display: flex;
				justify-content: center;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-bottom: 0.8rem;
			}
			.badge {
				display: inline-flex;
				align-items: center;
				padding: 0.35rem 0.7rem;
				border-radius: 999px;
				background: rgba(var(--accent), 0.08);
				color: rgb(var(--accent-dark));
				font-size: 0.9rem;
				font-weight: 600;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.tags {
				display: flex;
				gap: 0.5rem;
				justify-content: center;
				flex-wrap: wrap;
				margin-top: 1rem;
			}
			.tag {
				padding: 0.28rem 0.65rem;
				border-radius: 999px;
				background: rgba(var(--gray), 0.12);
				color: rgb(var(--gray-dark));
				font-size: 0.88rem;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img src={heroImage} alt={title} loading="eager" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="meta">
							<span class="badge">{category}</span>
						</div>
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
						{tags?.length > 0 && (
							<div class="tags">
								{tags.map((tag: string) => <span class="tag">#{tag}</span>)}
							</div>
						)}
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
