---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1rem;
		background: rgba(var(--surface), 0.92);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid rgba(var(--gray), 0.16);
		position: sticky;
		top: 0;
		z-index: 10;
	}
	h2 {
		margin: 0;
		font-size: 1rem;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		width: min(var(--max-content), calc(100% - 0.5rem));
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		min-height: 64px;
	}
	nav a {
		padding: 1rem 0.5rem;
		color: rgb(var(--black));
		border-bottom: 3px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		flex-wrap: wrap;
	}
	@media (max-width: 640px) {
		header {
			padding: 0 0.75rem;
		}
		nav {
			min-height: auto;
			padding: 0.4rem 0;
			align-items: flex-start;
			flex-direction: column;
		}
		.internal-links {
			width: 100%;
			gap: 0.1rem 0.6rem;
		}
		nav a {
			padding: 0.55rem 0.15rem;
		}
	}
</style>
