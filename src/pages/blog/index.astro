---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getBlogPosts, shouldIncludeDrafts } from '../../lib/content';

const showDrafts = shouldIncludeDrafts();
const posts = (await getBlogPosts()).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.blog-shell {
				max-width: 1080px;
			}
			.blog-intro {
				max-width: 760px;
				margin-bottom: 2rem;
			}
			.blog-intro p {
				margin: 0.4rem 0 0;
			}
			ul {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1.25rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				min-width: 0;
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				grid-column: 1 / -1;
			}
			.card-link {
				display: block;
				padding: 1rem;
				border-radius: 18px;
				background: white;
				border: 1px solid rgba(var(--gray), 0.18);
				box-shadow: 0 10px 24px rgba(var(--black), 0.04);
				height: 100%;
			}
			ul li img {
				width: 100%;
				margin-bottom: 0.75rem;
				border-radius: 14px;
				aspect-ratio: 2 / 1;
				object-fit: cover;
			}
			.category {
				margin: 0 0 0.45rem;
				font-size: 0.84rem;
				font-weight: 800;
				letter-spacing: 0.02em;
				color: rgb(var(--accent-dark));
			}
			.description {
				margin: 0.65rem 0 0;
				color: rgb(var(--gray-dark));
				line-height: 1.55;
				font-size: 0.98rem;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.2;
			}
			.date {
				margin: 0.2rem 0 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			.card-link:hover {
				transform: translateY(-2px);
				box-shadow: var(--box-shadow);
			}
			.card-link:hover h4,
			.card-link:hover .date {
				color: rgb(var(--accent));
			}
			@media (max-width: 900px) {
				ul {
					grid-template-columns: 1fr;
				}
			}
			@media (max-width: 720px) {
				.blog-intro {
					margin-bottom: 1.2rem;
				}
				.card-link {
					padding: 0.85rem;
					border-radius: 16px;
				}
				.description {
					font-size: 0.95rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="blog-shell">
			<section>
				<div class="blog-intro">
					<h1>Blog</h1>
					<p>AI 자동화, 서버 운영, NAS, 도구, 그리고 점점 넓어질 일상 기록.</p>
					{showDrafts && <p><strong>Preview mode:</strong> draft 글도 함께 표시 중.</p>}
				</div>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a class="card-link" href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<img src={post.data.heroImage} alt={post.data.title} />
									)}
									<p class="category">{post.data.category}</p>
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<p class="description">{post.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
